/* pages/report/report.wxss - 睡眠分期报告页样式（View柱状图版） */

.report-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 0 20rpx;
}

/* ========== 日期选择器 ========== */
.date-picker-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  gap: 16rpx;
}
.date-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
}
.date-icon { font-size: 28rpx; }
.date-text { font-size: 30rpx; color: #1a73e8; font-weight: 600; }
.date-arrow { font-size: 20rpx; color: #999; }
.refresh-tip { font-size: 24rpx; color: #1a73e8; animation: pulse 1.2s infinite; }
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }

.data-source {
  font-size: 22rpx; color: #999;
  background: #f0f0f0; padding: 4rpx 16rpx; border-radius: 20rpx;
}

/* ========== 图例 ========== */
.legend-bar {
  display: flex; justify-content: center;
  gap: 30rpx; padding: 16rpx 0 20rpx; flex-wrap: wrap;
}
.legend-item { display: flex; align-items: center; gap: 8rpx; }
.legend-dot { width: 20rpx; height: 20rpx; border-radius: 50%; }
.dot-awake { background: #ff6b6b; }
.dot-light { background: #51cf66; }
.dot-deep  { background: #339af0; }
.dot-rem   { background: #cc5de8; }
.legend-item text { font-size: 24rpx; color: #666; }

/* ========== View 柱状图（核心）========== */
.chart-wrapper {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
}

.chart-title {
  text-align: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 16rpx;
}

.chart-body {
  display: flex;
  flex-direction: row;
}

/* Y轴 */
.y-axis {
  width: 56rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 6rpx 0;
  flex-shrink: 0;
}
.y-label {
  height: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 8rpx;
}
.y-label text {
  font-size: 20rpx;
  color: #888;
  writing-mode: horizontal-tb;
}

/* 图表区域 */
.chart-area {
  flex: 1;
  display: flex;
  flex-direction: column;
}

/* 网格 + 柱子容器 */
.chart-grid {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: row;
  min-height: 280rpx;
  border-left: 1rpx solid #eee;
  border-bottom: 1rpx solid #ddd;
}
/* 4条水平网格线 */
.grid-line {
  position: absolute;
  left: 0; right: 0;
  height: 1rpx;
  background: #f0f0f0;
}
.grid-line:nth-child(1) { top: 0; }
.grid-line:nth-child(2) { top: 25%; }
.grid-line:nth-child(3) { top: 50%; }
.grid-line:nth-child(4) { top: 75%; }

/* 柱子容器：flex 横排，底部对齐 */
.bars-container {
  display: flex;
  flex-direction: row;
  align-items: flex-end;
  width: 100%;
  height: 100%;
  padding: 0 4rpx;
  box-sizing: border-box;
}

/* 每根柱子的列 */
.bar-col {
  flex: 1;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 0 1rpx;
}

/* 柱子本体：圆角 + 颜色 */
.bar {
  width: 90%;
  border-radius: 3rpx 3rpx 0 0;
  min-height: 6rpx;
  transition: all 0.3s ease;
}
.bar-awake { background: #ff6b6b; }
.bar-light { background: #51cf66; }
.bar-deep  { background: #339af0; }
.bar-rem   { background: #cc5de8; }

/* X轴时间标签 */
.x-axis {
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  padding-top: 8rpx;
  height: 40rpx;
}
.x-label {
  font-size: 18rpx;
  color: #999;
  flex: 1;
  text-align: center;
}

/* ========== 统计摘要 ========== */
.summary-section { margin-bottom: 40rpx; }
.summary-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}
.summary-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
  text-align: center;
}
.summary-grid { display: flex; justify-content: space-around; }
.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}
.summary-value { font-size: 44rpx; font-weight: 800; }
.summary-value.awake { color: #ff6b6b; }
.summary-value.light { color: #51cf66; }
.summary-value.deep  { color: #339af0; }
.summary-value.rem   { color: #cc5de8; }
.summary-label { font-size: 22rpx; color: #888; }

/* ========== 空状态/错误 ========== */
.empty-state, .error-state { text-align: center; padding-top: 200rpx; }
.empty-text { font-size: 28rpx; color: #999; }
.error-text { font-size: 28rpx; color: #e53935; display: block; margin-bottom: 20rpx; }
.retry-btn { background: #1a73e8 !important; color: #fff !important; }

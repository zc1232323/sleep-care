<!--pages/report/report.wxml - 睡眠分期报告页（第5大节）-->
<!-- 柱状图用 view 元素实现，避免 Canvas 2D Timeout 兼容性问题 -->
<view class="report-container">
  <!-- 日期选择器 -->
  <view class="date-picker-bar">
    <picker mode="date" value="{{selectedDate}}" bindchange="onDateChange" start="2026-06-01" end="{{today}}">
      <view class="date-btn">
        <text class="date-icon">📅</text>
        <text class="date-text">{{selectedDate}}</text>
        <text class="date-arrow">▼</text>
      </view>
    </picker>
    <text class="refresh-tip" wx:if="{{loading}}">加载中...</text>
    <text class="data-source" wx:if="{{dataSource}}">({{dataSource}})</text>
  </view>

  <!-- 图例说明 -->
  <view class="legend-bar">
    <view class="legend-item"><view class="legend-dot dot-awake"></view><text>清醒</text></view>
    <view class="legend-item"><view class="legend-dot dot-light"></view><text>浅睡</text></view>
    <view class="legend-item"><view class="legend-dot dot-deep"></view><text>深睡</text></view>
    <view class="legend-item"><view class="legend-dot dot-rem"></view><text>REM</text></view>
  </view>

  <!-- ========== View 柱状图（纯 DOM 实现）========== -->
  <view class="chart-wrapper" wx:if="{{stagesData}}">
    <!-- 图表标题 -->
    <view class="chart-title">睡眠分期曲线</view>

    <view class="chart-body">
      <!-- Y轴标签 -->
      <view class="y-axis">
        <view class="y-label"><text>REM</text></view>
        <view class="y-label"><text>深睡</text></view>
        <view class="y-label"><text>浅睡</text></view>
        <view class="y-label"><text>清醒</text></view>
      </view>

      <!-- 图表区域（网格 + 柱子） -->
      <view class="chart-area">
        <!-- 4条网格线 + 48根柱子 -->
        <view class="chart-grid">
          <!-- 网格线 -->
          <view class="grid-line"></view>
          <view class="grid-line"></view>
          <view class="grid-line"></view>
          <view class="grid-line"></view>

          <!-- 柱子容器：flex 横排 -->
          <view class="bars-container">
            <block wx:for="{{stagesData}}" wx:key="time">
              <view class="bar-col">
                <view class="bar {{item.stageClass}}" style="height: {{item.barHeight}}%;"></view>
              </view>
            </block>
          </view>
        </view>

        <!-- X轴时间标签 -->
        <view class="x-axis">
          <block wx:for="{{xLabels}}" wx:key="*this">
            <text class="x-label">{{item}}</text>
          </block>
        </view>
      </view>
    </view>
  </view>

  <!-- 统计摘要 -->
  <view class="summary-section" wx:if="{{summary}}">
    <view class="summary-card">
      <text class="summary-title">分期统计（{{selectedDate}}）</text>
      <view class="summary-grid">
        <view class="summary-item">
          <text class="summary-value awake">{{summary.awake}}</text>
          <text class="summary-label">清醒(次)</text>
        </view>
        <view class="summary-item">
          <text class="summary-value light">{{summary.light}}</text>
          <text class="summary-label">浅睡(次)</text>
        </view>
        <view class="summary-item">
          <text class="summary-value deep">{{summary.deep}}</text>
          <text class="summary-label">深睡(次)</text>
        </view>
        <view class="summary-item">
          <text class="summary-value rem">{{summary.rem}}</text>
          <text class="summary-label">REM(次)</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && !stagesData && !error}}">
    <text class="empty-text">暂无数据，请选择日期查看</text>
  </view>

  <!-- 错误提示 -->
  <view class="error-state" wx:if="{{error}}">
    <text class="error-text">{{error}}</text>
    <button class="retry-btn" bindtap="loadStages" size="mini">重试</button>
  </view>
</view>

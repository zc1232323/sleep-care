/* pages/devices/devices.wxss */
.devices-container {
  min-height: 100vh;
  background: #f5f5f5;
  padding: 30rpx;
}

.page-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0 30rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1a73e8;
}

.header-count {
  font-size: 26rpx;
  color: #999;
}

.device-list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.device-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  display: flex;
  align-items: center;
  gap: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.06);
}

.device-icon {
  width: 96rpx;
  height: 96rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.device-icon.online {
  background: linear-gradient(135deg, #e8f5e9, #c8e6c9);
}

.device-icon.offline {
  background: linear-gradient(135deg, #fafafa, #eeeeee);
}

.icon-text {
  font-size: 48rpx;
}

.device-icon.online .icon-text {
  color: #4caf50;
}

.device-icon.offline .icon-text {
  color: #bdbdbd;
}

.device-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.device-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.device-serial {
  font-size: 24rpx;
  color: #666;
}

.device-time {
  font-size: 22rpx;
  color: #999;
}

.status-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.tag-online {
  background: #e8f5e9;
}

.tag-online text {
  color: #4caf50;
  font-size: 24rpx;
  font-weight: 500;
}

.tag-offline {
  background: #f5f5f5;
}

.tag-offline text {
  color: #999;
  font-size: 24rpx;
  font-weight: 500;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 200rpx;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: #f0f0f0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.empty-emoji {
  font-size: 80rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
  margin-top: 30rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #bbb;
  margin-top: 12rpx;
}

.loading {
  text-align: center;
  padding-top: 200rpx;
  color: #999;
  font-size: 28rpx;
}

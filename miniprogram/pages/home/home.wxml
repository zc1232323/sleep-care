<!--pages/home/home.wxml-->
<view class="home-container">
  <!-- 顶部日期栏 + 退出按钮 -->
  <view class="date-bar">
    <text class="date-text">{{reportDate}}</text>
    <view class="logout-btn" bindtap="onLogout" wx:if="{{hasToken}}">
      <text class="logout-text">退出</text>
    </view>
  </view>

  <!-- 睡眠评分卡片 -->
  <view class="sleep-card" wx:if="{{reportData && !refreshing}}">
    <view class="card-header">
      <text class="card-title">睡眠质量</text>
      <text class="card-date">{{reportData.report_date}}</text>
    </view>

    <!-- 大数字评分 -->
    <view class="score-section">
      <text class="score-number {{scoreLevel}}">{{reportData.sleep_score}}</text>
      <text class="score-label">睡眠评分</text>
    </view>

    <!-- 指标网格 -->
    <view class="metrics-grid">
      <view class="metric-item">
        <text class="metric-value">{{reportData.total_duration}}</text>
        <text class="metric-label">总时长</text>
      </view>
      <view class="metric-item">
        <text class="metric-value">{{reportData.deep_ratio}}</text>
        <text class="metric-label">深睡比例</text>
      </view>
      <view class="metric-item">
        <text class="metric-value">{{reportData.awake_count}}次</text>
        <text class="metric-label">觉醒次数</text>
      </view>
    </view>

    <!-- 详细数据 -->
    <view class="detail-section">
      <view class="detail-row">
        <text class="detail-label">深睡时长</text>
        <text class="detail-value">{{reportData.deep_duration}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">浅睡时长</text>
        <text class="detail-value">{{reportData.light_duration}}</text>
      </view>
      <view class="detail-row">
        <text class="detail-label">清醒时长</text>
        <text class="detail-value">{{reportData.awake_duration}}</text>
      </view>
    </view>

    <!-- 查看详细分期按钮（第5大节） -->
    <view class="action-bar">
      <button class="btn-detail" bindtap="goToReport" hover-class="btn-detail-hover">
        📊 查看详细分期
      </button>
      <button class="btn-settings" bindtap="goToSettings" hover-class="btn-settings-hover">
        ⚙️ 作息设置
      </button>
      <button class="btn-doctor" bindtap="goToDoctor" hover-class="btn-doctor-hover">
        👨‍⚕️ 医生授权
      </button>
    </view>
  </view>

  <!-- 下拉刷新动画区域 -->
  <view class="refresh-area" wx:if="{{refreshing}}">
    <view class="refresh-spinner"></view>
    <text class="refresh-text">正在刷新...</text>
  </view>

  <!-- 刷新中的骨架屏/占位（保持卡片高度不变） -->
  <view class="sleep-card skeleton" wx:if="{{refreshing && reportData}}">
    <view class="skeleton-line skeleton-title"></view>
    <view class="skeleton-score"></view>
    <view class="skeleton-grid">
      <view class="skeleton-box"></view>
      <view class="skeleton-box"></view>
      <view class="skeleton-box"></view>
    </view>
  </view>

  <!-- 加载中（首次） -->
  <view class="loading-state" wx:if="{{loading && !refreshing && !reportData}}">
    <view class="loading-dots">
      <text class="dot dot-1">●</text>
      <text class="dot dot-2">●</text>
      <text class="dot dot-3">●</text>
    </view>
    <text class="loading-text">加载中...</text>
  </view>

  <!-- 空状态（未登录） -->
  <view class="empty-state" wx:if="{{!loading && !reportData && !hasToken}}">
    <view class="empty-icon">
      <text class="empty-emoji">😴</text>
    </view>
    <text class="empty-text">请先登录查看睡眠报告</text>
  </view>
</view>

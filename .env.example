# SleepCare 生产环境环境变量示例（第13大节：部署上线）
# 复制本文件为 .env 并按实际云数据库信息修改

PORT=3000

# 数据库切换：sqlite / mysql
DATABASE_TYPE=mysql

# MySQL 连接信息（CloudBase 内网地址示例）
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your-password
MYSQL_DATABASE=sleep_care

# JWT 签名密钥（生产环境请务必换成强随机字符串）
JWT_SECRET=sleep-care-secret-key-2026

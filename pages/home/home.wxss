/* pages/home/home.wxss */
.home-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a73e8 0%, #4a90d9 25%, #f5f5f5 28%);
  padding: 0 30rpx;
}

/* 日期栏 */
.date-bar {
  padding: 20rpx 0 10rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.date-text {
  color: rgba(255,255,255,0.9);
  font-size: 28rpx;
}

/* 退出按钮 */
.logout-btn {
  padding: 8rpx 24rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
}

.logout-text {
  color: #fff;
  font-size: 24rpx;
}

/* 睡眠卡片 */
.sleep-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx 32rpx;
  box-shadow: 0 8rpx 30rpx rgba(0,0,0,0.08);
  margin-top: 16rpx;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #333;
}

.card-date {
  font-size: 26rpx;
  color: #999;
}

/* 评分区域 */
.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 36rpx;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 30rpx;
}

.score-number {
  font-size: 120rpx;
  font-weight: 800;
  line-height: 1.1;
}

.score-number.excellent {
  color: #4caf50;
}
.score-number.good {
  color: #8bc34a;
}
.score-number.fair {
  color: #ff9800;
}
.score-number.poor {
  color: #f44336;
}

.score-label {
  font-size: 26rpx;
  color: #888;
  margin-top: 8rpx;
}

/* 指标网格 */
.metrics-grid {
  display: flex;
  justify-content: space-around;
  margin-bottom: 30rpx;
  padding: 16rpx 0;
  background: #fafafa;
  border-radius: 16rpx;
}

.metric-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.metric-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a73e8;
}

.metric-label {
  font-size: 22rpx;
  color: #999;
}

/* 详细数据 */
.detail-section {
  border-top: 1rpx solid #f0f0f0;
  padding-top: 24rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
}

.detail-label {
  font-size: 27rpx;
  color: #666;
}

.detail-value {
  font-size: 27rpx;
  font-weight: 600;
  color: #333;
}

/* 加载状态 */
.loading-state, .refresh-tip, .empty-state {
  text-align: center;
  padding-top: 200rpx;
}

.loading-state text, .refresh-tip text {
  color: #999;
  font-size: 28rpx;
}

.refresh-tip text {
  color: #1a73e8;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  background: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.empty-emoji {
  font-size: 80rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  display: block;
}

/* ========== 下拉刷新动画 ========== */
.refresh-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0 40rpx;
}

.refresh-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #1a73e8;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.refresh-text {
  font-size: 28rpx;
  color: #1a73e8;
  font-weight: 500;
}

/* ========== 骨架屏（刷新时显示） ========== */
.skeleton {
  opacity: 0.6;
}

.skeleton-line {
  height: 36rpx;
  width: 200rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 8rpx;
  margin-bottom: 30rpx;
}

.skeleton-title {
  width: 160rpx !important;
}

.skeleton-score {
  width: 140rpx;
  height: 120rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 16rpx;
  margin: 30rpx auto;
}

.skeleton-grid {
  display: flex;
  justify-content: space-around;
  padding: 20rpx 0;
}

.skeleton-box {
  width: 100rpx;
  height: 70rpx;
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
  border-radius: 12rpx;
}

@keyframes shimmer {
  0% { background-position: -200% 0; }
  100% { background-position: 200% 0; }
}

/* ========== 加载动画（首次加载） ========== */
.loading-dots {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.dot {
  font-size: 40rpx;
  color: #1a73e8;
  opacity: 0.3;
  animation: dotBounce 1.4s ease-in-out infinite;
}

.dot-1 { animation-delay: 0s; }
.dot-2 { animation-delay: 0.2s; }
.dot-3 { animation-delay: 0.4s; }

@keyframes dotBounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.3; }
  40% { transform: scale(1.2); opacity: 1; }
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 查看详细分期按钮（第5大节）========== */
.action-bar {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx 0;
}

.btn-detail {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  text-align: center;
  border: none;
  letter-spacing: 4rpx;
}

.btn-detail-hover {
  opacity: 0.85;
}

.btn-settings {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  color: #1a73e8;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  text-align: center;
  border: 2rpx solid #1a73e8;
}

.btn-settings-hover {
  opacity: 0.7;
  background: #f0f4ff;
}

.btn-doctor {
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  background: #fff;
  color: #e67700;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 40rpx;
  text-align: center;
  border: 2rpx solid #e67700;
}

.btn-doctor-hover {
  opacity: 0.7;
  background: #fff4e6;
}

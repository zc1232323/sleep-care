<!--pages/devices/devices.wxml—— 对齐讲义字段：nickname, serial_no, online_status -->
<view class="devices-container">
  <!-- 页面头部 -->
  <view class="page-header">
    <text class="header-title">我的设备</text>
    <text class="header-count">共 {{deviceList.length}} 台设备</text>
  </view>

  <!-- 设备列表 -->
  <view class="device-list" wx:if="{{deviceList.length > 0}}">
    <view
      class="device-card"
      wx:for="{{deviceList}}"
      wx:key="id"
    >
      <!-- 设备图标（online_status: 1在线 0离线） -->
      <view class="device-icon {{item.online_status === 1 ? 'online' : 'offline'}}">
        <text class="icon-text">{{item.online_status === 1 ? '●' : '○'}}</text>
      </view>

      <!-- 设备信息（使用 nickname 字段） -->
      <view class="device-info">
        <text class="device-name">{{item.nickname}}</text>
        <text class="device-serial">序列号：{{item.serial_no}}</text>
        <text class="device-time">{{item.created_at}}</text>
      </view>

      <!-- 在线状态标签 -->
      <view class="status-tag {{item.online_status === 1 ? 'tag-online' : 'tag-offline'}}">
        <text>{{item.online_status === 1 ? '在线' : '离线'}}</text>
      </view>

      <!-- 删除按钮 -->
      <view class="delete-btn" bindtap="handleDelete" data-id="{{item.id}}">
        <text>删除</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:if="{{!loading && deviceList.length === 0}}">
    <view class="empty-icon">
      <text class="empty-emoji">📱</text>
    </view>
    <text class="empty-text">暂无已绑定设备</text>
    <text class="empty-hint">请先添加智能穿戴设备</text>
  </view>

  <!-- 添加虚拟设备按钮 -->
  <view class="add-device-btn" bindtap="handleAddDevice">
    <text>+ 添加虚拟设备</text>
  </view>

  <!-- 加载中 -->
  <view class="loading" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
</view>

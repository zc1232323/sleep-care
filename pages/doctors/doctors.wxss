/* pages/doctors/doctors.wxss - 第10大节：医生授权管理页样式（卡片列表选择） */

.doctor-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx 20rpx;
}

/* ====== 页面头部 ====== */
.page-header {
  text-align: center;
  padding-bottom: 28rpx;
}
.page-title {
  font-size: 36rpx;
  font-weight: 800;
  color: #222;
  display: block;
}
.page-desc {
  font-size: 25rpx;
  color: #999;
  display: block;
  margin-top: 6rpx;
}

/* ====== 选择医生区域 ====== */
.select-section {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  margin-bottom: 28rpx;
}

.section-label {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 20rpx;
}

.empty-doctors {
  text-align: center;
  padding: 60rpx 20rpx;
  background: #f8f9fa;
  border-radius: 16rpx;
}
.empty-doctors .empty-emoji {
  font-size: 60rpx;
  display: block;
  margin-bottom: 12rpx;
}
.empty-doctors .empty-text {
  font-size: 28rpx;
  color: #999;
}

.doctor-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  max-height: 560rpx;
  overflow-y: auto;
}

.select-card {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 22rpx 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid #e8e8e8;
  background: #fafafa;
  transition: all 0.2s;
}
.select-card.selected {
  border-color: #1a73e8;
  background: #f0f7ff;
  box-shadow: 0 4rpx 16rpx rgba(26,115,232,0.12);
}
.select-card:active {
  opacity: 0.8;
}

.select-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: #e8f4fd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.select-avatar .avatar-icon {
  font-size: 36rpx;
}

.select-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}
.select-name {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
}
.select-phone {
  font-size: 26rpx;
  color: #888;
}

.check-icon {
  width: 44rpx;
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 50%;
  background: #1a73e8;
  color: #fff;
  font-size: 26rpx;
  text-align: center;
  font-weight: 700;
}

.selected-bar {
  margin-top: 24rpx;
  padding: 18rpx 20rpx;
  border-radius: 12rpx;
  background: #e8f4fd;
  text-align: center;
}
.selected-bar.placeholder {
  background: #f5f5f5;
}
.selected-text {
  font-size: 28rpx;
  color: #1a73e8;
  font-weight: 600;
}
.selected-bar.placeholder .selected-text {
  color: #999;
}

.grant-btn {
  width: 100%;
  height: 84rpx;
  line-height: 84rpx;
  background: #1a73e8;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 42rpx;
  text-align: center;
  border: none;
  margin-top: 24rpx;
  letter-spacing: 4rpx;
}
.grant-btn.disabled {
  background: #bbb;
}
.grant-btn::after { border: none; }

/* ====== 已授权列表标题 ====== */
.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 16rpx;
  padding-left: 8rpx;
}

/* ====== 加载中 ====== */
.loading-box {
  text-align: center;
  padding-top: 200rpx;
}
.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* ====== 空状态 ====== */
.empty-state {
  text-align: center;
  padding-top: 160rpx;
}
.empty-emoji {
  font-size: 100rpx;
  display: block;
  margin-bottom: 20rpx;
}
.empty-text {
  font-size: 30rpx;
  color: #666;
  display: block;
  margin-bottom: 10rpx;
}
.empty-hint {
  font-size: 25rpx;
  color: #bbb;
  display: block;
}

/* ====== 已授权医生卡片列表 ====== */
.doctor-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.doctor-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.card-top {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.doc-avatar {
  width: 84rpx;
  height: 84rpx;
  border-radius: 50%;
  background: #e8f4fd;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}
.doc-avatar .avatar-icon {
  font-size: 38rpx;
}

.doc-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.doc-name {
  font-size: 32rpx;
  font-weight: 700;
  color: #222;
}
.doc-phone {
  font-size: 26rpx;
  color: #888;
}

.status-tag {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 600;
  white-space: nowrap;
  flex-shrink: 0;
}
.status-pending {
  background: #fff3cd;
  color: #856404;
}
.status-active {
  background: #d3f9d8;
  color: #198754;
}

.card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #eee;
}

.expire-info {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
}
.expire-label {
  font-size: 24rpx;
  color: #999;
}
.expire-date {
  font-size: 26rpx;
  color: #333;
  font-weight: 600;
}

.revoke-btn {
  width: 120rpx;
  height: 60rpx;
  line-height: 60rpx;
  background: #fff;
  color: #e53935;
  font-size: 26rpx;
  font-weight: 600;
  border: 2rpx solid #ffcdd2;
  border-radius: 30rpx;
  text-align: center;
  padding: 0;
}
.revoke-btn::after { border: none; }
.revoke-btn:hover {
  background: #fce4ec;
}

/* 错误 */
.error-state {
  text-align: center;
  padding-top: 200rpx;
}
.error-text {
  font-size: 28rpx;
  color: #e53935;
  display: block;
  margin-bottom: 20rpx;
}
.retry-btn {
  background: #1a73e8 !important;
  color: #fff !important;
}

/* pages/report/report.wxss - 睡眠分期报告页样式 */

.report-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 0 20rpx;
}

/* ========== 日期选择器 ========== */
.date-picker-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  gap: 16rpx;
}

.date-btn {
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: #fff;
  border: 2rpx solid #e0e0e0;
  border-radius: 40rpx;
  padding: 16rpx 32rpx;
}

.date-icon {
  font-size: 28rpx;
}

.date-text {
  font-size: 30rpx;
  color: #1a73e8;
  font-weight: 600;
}

.date-arrow {
  font-size: 20rpx;
  color: #999;
}

.refresh-tip {
  font-size: 24rpx;
  color: #1a73e8;
  animation: pulse 1.2s infinite;
}

@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.4; }
}

.data-source {
  font-size: 22rpx;
  color: #999;
  background: #f0f0f0;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

/* ========== 图例 ========== */
.legend-bar {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  padding: 16rpx 0 24rpx;
  flex-wrap: wrap;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.legend-dot {
  width: 20rpx;
  height: 20rpx;
  border-radius: 50%;
}

.dot-awake { background: #ff6b6b; }
.dot-light { background: #51cf66; }
.dot-deep { background: #339af0; }
.dot-rem { background: #cc5de8; }

legend-item text {
  font-size: 24rpx;
  color: #666;
}

/* ========== ECharts 图表 ========== */
.chart-wrapper {
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
}

ec-canvas {
  width: 100%;
  height: 500rpx;
}

/* ========== 统计摘要 ========== */
.summary-section {
  margin-bottom: 40rpx;
}

.summary-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.summary-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #333;
  display: block;
  margin-bottom: 24rpx;
  text-align: center;
}

.summary-grid {
  display: flex;
  justify-content: space-around;
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.summary-value {
  font-size: 44rpx;
  font-weight: 800;
}

.summary-value.awake { color: #ff6b6b; }
.summary-value.light { color: #51cf66; }
.summary-value.deep { color: #339af0; }
.summary-value.rem { color: #cc5de8; }

.summary-label {
  font-size: 22rpx;
  color: #888;
}

/* ========== 空状态/错误 ========== */
.empty-state, .error-state {
  text-align: center;
  padding-top: 200rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.error-text {
  font-size: 28rpx;
  color: #e53935;
  display: block;
  margin-bottom: 20rpx;
}

.retry-btn {
  background: #1a73e8 !important;
  color: #fff !important;
}

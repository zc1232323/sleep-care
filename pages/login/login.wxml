<!--pages/login/login.wxml-->
<view class="login-container">
  <view class="logo-area">
    <view class="logo">
      <text class="logo-text">😴</text>
    </view>
    <text class="app-name">SleepCare</text>
    <text class="app-desc">智能睡眠健康管理</text>
  </view>

  <view class="login-form">
    <view class="form-item">
      <input
        class="input-field"
        type="number"
        placeholder="请输入手机号"
        maxlength="11"
        value="{{phone}}"
        bindinput="onPhoneInput"
      />
    </view>

    <view class="form-item">
      <input
        class="input-field"
        type="text"
        password="{{true}}"
        placeholder="{{isRegister ? '设置密码(至少6位)' : '请输入密码'}}"
        value="{{password}}"
        bindinput="onPasswordInput"
      />
    </view>

    <view class="form-item" wx:if="{{isRegister}}">
      <input
        class="input-field"
        type="text"
        password="{{true}}"
        placeholder="请确认密码"
        value="{{confirmPassword}}"
        bindinput="onConfirmPasswordInput"
      />
    </view>

    <view class="form-item" wx:if="{{isRegister}}">
      <input
        class="input-field"
        type="text"
        placeholder="昵称(选填)"
        maxlength="20"
        value="{{nickname}}"
        bindinput="onNicknameInput"
      />
    </view>

    <button
      class="btn-login {{loading ? 'disabled' : ''}}"
      disabled="{{loading}}"
      bindtap="{{isRegister ? 'onRegister' : 'onLogin'}}"
    >
      {{loading ? (isRegister ? '注册中...' : '登录中...') : (isRegister ? '注 册' : '登 录')}}
    </button>
  </view>

  <view class="switch-mode">
    <text class="switch-text">{{isRegister ? '已有账号?' : '没有账号?'}}</text>
    <text class="switch-link" bindtap="toggleMode">{{isRegister ? '去登录' : '立即注册'}}</text>
  </view>

  <view class="tips" wx:if="{{errorMsg}}">
    <text class="error-text">{{errorMsg}}</text>
  </view>
</view>

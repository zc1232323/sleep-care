/* pages/settings/settings.wxss - 第8大节：作息设置页面样式 */

.settings-container {
  min-height: 100vh;
  background: #f5f7fa;
  padding: 24rpx 20rpx;
}

/* 加载中 */
.loading-box {
  text-align: center;
  padding-top: 300rpx;
}
.loading-text {
  font-size: 28rpx;
  color: #999;
}

/* 卡片式布局 */
.settings-form {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.setting-card {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx 28rpx 28rpx 24rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.card-icon {
  font-size: 44rpx;
  width: 72rpx;
  text-align: center;
  flex-shrink: 0;
}

.card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  padding-left: 8rpx;
}

.card-label {
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
}

.card-desc {
  font-size: 24rpx;
  color: #999;
}

/* picker 时间选择器 */
.picker-value {
  display: flex;
  align-items: center;
  gap: 4rpx;
  padding: 8rpx 16rpx;
  background: #f0f4ff;
  border-radius: 12rpx;
}

.time-text {
  font-size: 34rpx;
  font-weight: 700;
  color: #1a73e8;
}

.picker-arrow {
  font-size: 32rpx;
  color: #1a73e8;
  font-weight: 300;
}

/* slider 卡片 */
.slider-card {
  flex-direction: column;
  align-items: stretch;
  padding: 28rpx;
}

.slider-section {
  margin-top: 20rpx;
}

.slider-value-box {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 12rpx;
}

.slider-value {
  font-size: 56rpx;
  font-weight: 800;
  color: #1a73e8;
}

.slider-unit {
  font-size: 26rpx;
  color: #999;
  margin-left: 6rpx;
}

.duration-slider {
  width: 100%;
  margin: 8rpx 0;
}

.slider-range {
  display: flex;
  justify-content: space-between;
}

.range-text {
  font-size: 22rpx;
  color: #bbb;
}

/* 保存按钮 */
.save-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #1a73e8, #4a90d9);
  color: #fff;
  font-size: 32rpx;
  font-weight: 700;
  border-radius: 48rpx;
  border: none;
  margin-top: 20rpx;
  transition: all 0.2s;
}

.save-btn.saving {
  background: #bbb;
  opacity: 0.8;
}

.save-btn::after {
  border: none;
}

.save-btn-hover {
  opacity: 0.85;
  transform: scale(0.98);
}
